{
  "name": "comfy-front",
  "version": "0.1.0",
  "type": "module",
  "homepage": "https://michaelgossage.github.io/ComfyFront",
  "scripts": {
    "dev": "concurrently \"vite\" \"node server.js\"",
    "server": "node server.js",
    "frontend": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist",
    "build-pv": "vite build --config vite.client.config.js && mv dist-client/index-client.html dist-client/index.html",
    "predeploy-pv": "npm run build-pv",
    "deploy-pv": "gh-pages -d dist-client"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1048.0",
    "concurrently": "^9.2.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "gh-pages": "^6.3.0",
    "vite": "^5.4.2"
  }
}
